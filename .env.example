# AI (Groq) — required today for the AI assistant and listing generator
GROQ_API_KEY=

# Public site URL — used for metadata, sitemap.xml, and robots.txt
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Backend integration ---
# Neon Postgres — get this from your Neon project dashboard
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=

# Neon Auth — enable Auth for your project first:
# Neon Console -> your project -> Branch -> Auth -> Configuration
# NEON_AUTH_BASE_URL is the "Auth URL" shown there, e.g.
# https://ep-xxxx.neonauth.us-east-1.aws.neon.tech/neondb/auth
NEON_AUTH_BASE_URL=

# Cookie signing secret for Neon Auth sessions — generate with:
# openssl rand -base64 32
NEON_AUTH_COOKIE_SECRET=

# PayHero
# PAYHERO_API_KEY=
# PAYHERO_CHANNEL_ID=
# PAYHERO_WEBHOOK_SECRET=
